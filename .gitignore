# ============================================================
# Secrets & environment variables
# ============================================================
.env
.env.local
.env.*.local
*.pem
Config.xcconfig

# Local secrets notes (personal, never commit)
secrets.local.md
.secrets/

# Personal setup notes (not for the repo)
ACCOUNT_SETUP.md

# ============================================================
# iOS / Xcode
# ============================================================
# Generated by XcodeGen (`mint run xcodegen generate`) — do not commit
apps/ios/*.xcodeproj
apps/ios/build/
apps/ios/*.xcworkspace/xcuserdata/
apps/ios/DerivedData/

# Mint local install path (if MINT_PATH is set to a repo-local dir)
.mint/
apps/ios/*.ipa
apps/ios/*.dSYM.zip
apps/ios/*.dSYM

# Swift Package Manager
apps/ios/.build/
apps/ios/.swiftpm/
apps/ios/*.resolved

# Playgrounds
apps/ios/*.playground/timeline.xctimeline
apps/ios/*.playground/playground.xcworkspace

# ============================================================
# Web / Node.js
# ============================================================
apps/web/node_modules/
apps/web/.next/
apps/web/out/
apps/web/.vercel/
apps/web/coverage/

# ============================================================
# Supabase
# ============================================================
supabase/.branches/
supabase/.temp/

# ============================================================
# macOS
# ============================================================
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

