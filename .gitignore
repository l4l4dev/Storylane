# ============================================================
# iOS / Xcode
# ============================================================
# Generated by XcodeGen (`mint run xcodegen generate`) — do not commit
apps/ios/*.xcodeproj
apps/ios/Storylane/Info.plist
apps/ios/build/
apps/ios/*.xcworkspace/xcuserdata/
apps/ios/DerivedData/

# Mint local install path (if MINT_PATH is set to a repo-local dir)
.mint/
apps/ios/*.ipa
apps/ios/*.dSYM.zip
apps/ios/*.dSYM

# Swift Package Manager
apps/ios/.build/
apps/ios/.swiftpm/
apps/ios/*.resolved

# Playgrounds
apps/ios/*.playground/timeline.xctimeline
apps/ios/*.playground/playground.xcworkspace

# ============================================================
# Web / Node.js
# ============================================================
# pnpm workspace root is the repo root (TASK-68) — node_modules can appear
# at the root and inside any workspace member.
node_modules/
apps/web/.next/
apps/web/out/
apps/web/.vercel/
apps/web/coverage/

