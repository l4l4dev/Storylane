# apps/mcp credentials — copy to .env.local (gitignored) and fill in.
# The MCP server signs in as an ordinary Supabase user (the agent bot) and is
# gated by the same RLS as every other client — no service-role key here.

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-local-anon-key
AGENT_EMAIL=agent@example.com
AGENT_PASSWORD=the-bot-password

# Integration tests only (they seed data via the service role and sign the bot
# in with password auth against a running local Supabase):
#   SUPABASE_INTEGRATION=1 pnpm --dir apps/mcp exec vitest run
# SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
