# Supabase
# Get these from your Supabase project dashboard: Settings > API Keys
# Use the new key format (tab: "Publishable and secret API keys"),
# NOT the Legacy anon / service_role keys.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable key (prefix: sb_publishable_...) — client-side, safe to expose.
# Replaces the legacy "anon" key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx

# Secret key (prefix: sb_secret_...) — server-side only, never expose on the client.
# Replaces the legacy "service_role" key.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxx
